# Browser-safe Supabase Auth configuration. Use the same project as Sherlock-V2.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-only Sherlock backend origin. HTTPS is required in production.
SHERLOCK_API_URL=http://localhost:8787
